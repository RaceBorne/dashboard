{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/daily",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/outreach",
      "schedule": "0 14 * * 1-5"
    },
    {
      "path": "/api/cron/brand-refresh",
      "schedule": "0 5 * * 1"
    },
    {
      "path": "/api/cron/publish-scheduled",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/marketing-flows",
      "schedule": "*/5 * * * *"
    }
  ]
}
