# =============================================================================
# Evari Dashboard — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values you have. The dashboard
# is designed to run with mock data when credentials are absent, so you can
# add things one integration at a time. Restart `npm run dev` after edits.
# =============================================================================


# -- Site identity ------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="https://evari.cc"
NEXT_PUBLIC_DASHBOARD_NAME="Evari Dashboard"


# -- Authentication (optional, recommended before public deploy) --------------
# Vercel password protection is the simplest path. Enable it in the Vercel
# project settings rather than configuring NextAuth here.


# -- AI Gateway ---------------------------------------------------------------
# Default path: link the project to Vercel and run `vercel env pull` to get
# VERCEL_OIDC_TOKEN automatically. The AI SDK reads it via @vercel/oidc.
# Manual fallback: paste a gateway key from the Vercel dashboard.
AI_GATEWAY_API_KEY=""

# The model used for briefings, reply suggestions, social drafts, etc.
AI_MODEL="anthropic/claude-sonnet-4.6"

# Path to the bundled evari-copy skill (.skill is a zip; we extract SKILL.md
# at boot). If unset, dashboard falls back to a built-in mini brief style.
EVARI_COPY_SKILL_PATH="/Users/craigmcdonald/Dropbox (Personal)/Evari Speed Bikes/10 Marketing/Claude/evari-copy.skill"


# -- Shopify Admin API --------------------------------------------------------
# Create a custom app in Shopify admin > Settings > Apps and sales channels >
# Develop apps. Required scopes: read/write products, collections, content,
# orders, customers, draft orders.
SHOPIFY_STORE_DOMAIN=""           # e.g. evari-bikes.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=""     # shpat_...
SHOPIFY_API_VERSION="2025-01"


# -- Google Search Console + GA4 + Gmail --------------------------------------
# Create a Google Cloud project, enable Search Console API, GA4 Data API, and
# Gmail API. Create an OAuth 2.0 Client ID (Web). The redirect URI when
# running locally is http://localhost:3000/api/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REFRESH_TOKEN=""           # populated after first OAuth flow
GSC_SITE_URL="https://evari.cc/"
GA4_PROPERTY_ID=""                # e.g. 123456789
GMAIL_USER_EMAIL=""               # the inbox the dashboard reads from
GMAIL_LABEL_NAME="Evari/Leads"    # label on the lead pipeline


# -- PageSpeed Insights -------------------------------------------------------
# Optional API key for higher rate limits. The dashboard works without one.
PAGESPEED_API_KEY=""


# -- LinkedIn Marketing API ---------------------------------------------------
# Register an app at https://developer.linkedin.com — request Marketing
# Developer Platform access for the Evari company page.
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
LINKEDIN_ACCESS_TOKEN=""
LINKEDIN_ORGANIZATION_URN=""      # e.g. urn:li:organization:1234567


# -- Meta (Instagram Business) ------------------------------------------------
# Create a Meta app, link the Evari Instagram business account, request the
# instagram_content_publish + instagram_manage_insights permissions.
META_APP_ID=""
META_APP_SECRET=""
META_ACCESS_TOKEN=""              # long-lived page token
INSTAGRAM_BUSINESS_ACCOUNT_ID=""


# -- TikTok Content Posting + Business APIs -----------------------------------
# Register at https://developers.tiktok.com — apply for content.publish and
# user.info.basic + business.account.read.
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
TIKTOK_ACCESS_TOKEN=""
TIKTOK_REFRESH_TOKEN=""


# -- Cron --------------------------------------------------------------------
# Vercel sets this automatically when cron jobs are configured. Keep a value
# locally if you want to test the cron route from a browser.
CRON_SECRET=""


# -- Database (Neon Postgres via Vercel Marketplace) -------------------------
# Skip while running on mock data. When you provision Neon, Vercel will inject
# DATABASE_URL automatically and the data layer will switch from mock to live.
DATABASE_URL=""

# Google Places API (New) — primary source for the Source Prospects agent.
# Enable 'Places API (New)' in Google Cloud and restrict the key to that API.
GOOGLE_PLACES_API_KEY=

# -- Marketing system (Postmark) ---------------------------------------------
# Server token for Postmark. When set, the marketing sender swaps from STUB
# mode to live HTTP sends. Leave blank locally to keep dev safe.
POSTMARK_SERVER_TOKEN=""
# Required when POSTMARK_SERVER_TOKEN is set. Must be a verified sender on
# the configured Postmark account.
POSTMARK_FROM_EMAIL=""
# Optional display name for outbound email — wraps to "Name <email>".
POSTMARK_FROM_NAME=""
# Postmark message stream id. Defaults to "broadcast" if unset; create one
# in the Postmark dashboard under Servers → <server> → Message streams.
POSTMARK_MESSAGE_STREAM=""
# Shared secret for the inbound webhook receiver. Pass as ?token=... when
# configuring webhooks in Postmark. If unset the receiver accepts all
# requests (dev only — set in production).
POSTMARK_WEBHOOK_TOKEN=""
# Postmark account-level token. Required for the Domain auth module
# (Phase 8) — used to register sender domains and pull the auto-
# generated DKIM selector + value. Server token (above) is for sending;
# this is for managing servers + domains. Generate from Postmark
# account API tokens page.
POSTMARK_ACCOUNT_TOKEN=""
# HMAC secret used to sign / verify unsubscribe tokens emitted by
# the marketing system. Without this, falls back to CRON_SECRET, then
# to a dev placeholder. SET THIS in production — leaks would let
# anyone forge an unsubscribe URL for any address.
UNSUB_SECRET=""
# Public absolute URL of the dashboard (e.g. https://dashboard.evari.cc).
# Used to build unsubscribe links in outbound email. Falls back to
# VERCEL_PROJECT_PRODUCTION_URL when unset.
NEXT_PUBLIC_APP_URL=""
